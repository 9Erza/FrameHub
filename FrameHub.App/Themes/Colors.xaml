<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- FrameHub dark application theme. -->
    <Color x:Key="ColorWindowChrome">#060A12</Color>
    <Color x:Key="ColorBackground">#070B13</Color>
    <Color x:Key="ColorBackgroundAlt">#0A0F1C</Color>
    <Color x:Key="ColorSidebar">#0B1222</Color>
    <Color x:Key="ColorSurface">#0F172A</Color>
    <Color x:Key="ColorSurfaceAlt">#121D34</Color>
    <Color x:Key="ColorSurfaceHover">#1A2740</Color>
    <Color x:Key="ColorSurfaceSelected">#1B376A</Color>
    <Color x:Key="ColorBorder">#26344E</Color>
    <Color x:Key="ColorBorderSoft">#1C2941</Color>
    <Color x:Key="ColorPrimary">#5B8CFF</Color>
    <Color x:Key="ColorPrimaryDark">#2563EB</Color>
    <Color x:Key="ColorPrimarySoft">#152B58</Color>
    <Color x:Key="ColorCyan">#38BDF8</Color>
    <Color x:Key="ColorSuccess">#22C55E</Color>
    <Color x:Key="ColorWarning">#F59E0B</Color>
    <Color x:Key="ColorDanger">#EF4444</Color>
    <Color x:Key="ColorTextPrimary">#F8FAFC</Color>
    <Color x:Key="ColorTextSecondary">#B6C2D8</Color>
    <Color x:Key="ColorTextMuted">#74839B</Color>

    <SolidColorBrush x:Key="BrushWindowChrome" Color="{StaticResource ColorWindowChrome}" />
    <SolidColorBrush x:Key="BrushBackground" Color="{StaticResource ColorBackground}" />
    <SolidColorBrush x:Key="BrushBackgroundAlt" Color="{StaticResource ColorBackgroundAlt}" />
    <SolidColorBrush x:Key="BrushSidebar" Color="{StaticResource ColorSidebar}" />
    <SolidColorBrush x:Key="BrushSurface" Color="{StaticResource ColorSurface}" />
    <SolidColorBrush x:Key="BrushSurfaceAlt" Color="{StaticResource ColorSurfaceAlt}" />
    <SolidColorBrush x:Key="BrushSurfaceHover" Color="{StaticResource ColorSurfaceHover}" />
    <SolidColorBrush x:Key="BrushSurfaceSelected" Color="{StaticResource ColorSurfaceSelected}" />
    <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource ColorBorder}" />
    <SolidColorBrush x:Key="BrushBorderSoft" Color="{StaticResource ColorBorderSoft}" />
    <SolidColorBrush x:Key="BrushPrimary" Color="{StaticResource ColorPrimary}" />
    <SolidColorBrush x:Key="BrushPrimaryDark" Color="{StaticResource ColorPrimaryDark}" />
    <SolidColorBrush x:Key="BrushPrimarySoft" Color="{StaticResource ColorPrimarySoft}" />
    <SolidColorBrush x:Key="BrushCyan" Color="{StaticResource ColorCyan}" />
    <SolidColorBrush x:Key="BrushSuccess" Color="{StaticResource ColorSuccess}" />
    <SolidColorBrush x:Key="BrushWarning" Color="{StaticResource ColorWarning}" />
    <SolidColorBrush x:Key="BrushDanger" Color="{StaticResource ColorDanger}" />
    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource ColorTextSecondary}" />
    <SolidColorBrush x:Key="BrushTextMuted" Color="{StaticResource ColorTextMuted}" />

    <LinearGradientBrush x:Key="BrushAppBackground" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#070B13" Offset="0" />
        <GradientStop Color="#081121" Offset="0.45" />
        <GradientStop Color="#050812" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BrushHeroGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#13254A" Offset="0" />
        <GradientStop Color="#0F172A" Offset="0.55" />
        <GradientStop Color="#0A0F1C" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BrushPrimaryGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#5B8CFF" Offset="0" />
        <GradientStop Color="#38BDF8" Offset="1" />
    </LinearGradientBrush>
</ResourceDictionary>
