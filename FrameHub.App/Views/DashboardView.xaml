<UserControl x:Class="FrameHub.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <Border Style="{StaticResource HeroCardBorder}" Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="FRAMEHUB CORE" Style="{StaticResource PageEyebrowText}" />
                        <TextBlock Text="{Binding FoundationPlanTitle}" FontSize="24" FontWeight="SemiBold" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding FoundationPlanDescription}" Style="{StaticResource PageSubtitleText}" TextWrapping="Wrap" Margin="0,10,0,0" MaxWidth="780" />
                    </StackPanel>
                    <Border Grid.Column="1" Background="#132B4F" BorderBrush="#2D4470" BorderThickness="1" CornerRadius="18" Padding="18,14" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="{StaticResource BrushSuccess}" Margin="0,0,10,0" />
                            <TextBlock Text="Core online" FontWeight="SemiBold" Foreground="{StaticResource BrushTextSecondary}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <ItemsControl ItemsSource="{Binding Metrics}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource MetricCardBorder}" Margin="0,0,14,14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Width="42" Height="4" CornerRadius="4" Background="{Binding Accent}" HorizontalAlignment="Left" Margin="0,0,0,16" />
                                <StackPanel Grid.Row="1">
                                    <TextBlock Text="{Binding Title}" Style="{StaticResource CardTitleText}" />
                                    <TextBlock Text="{Binding Value}" Style="{StaticResource CardValueText}" Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding Detail}" Style="{StaticResource SmallMutedText}" Margin="0,8,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*" />
                    <ColumnDefinition Width="0.85*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,16,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="42" Height="42" CornerRadius="14" Background="{StaticResource BrushPrimarySoft}" Margin="0,0,14,0">
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="18" Foreground="{StaticResource BrushPrimary}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding TargetTitle}" Style="{StaticResource SectionTitleText}" />
                                <TextBlock Text="{Binding TargetDescription}" Style="{StaticResource SmallMutedText}" TextWrapping="Wrap" Margin="0,5,0,0" />
                            </StackPanel>
                        </Grid>

                        <Border Style="{StaticResource SoftCardBorder}" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="30" Height="30" CornerRadius="10" Background="#122C4F" Margin="0,0,12,0">
                                    <TextBlock Text="1" FontWeight="Bold" Foreground="{StaticResource BrushCyan}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="{Binding TargetTitle}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding TargetDescription}" Style="{StaticResource SmallMutedText}" Margin="0,4,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SoftCardBorder}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="30" Height="30" CornerRadius="10" Background="#132B4A" Margin="0,0,12,0">
                                    <TextBlock Text="2" FontWeight="Bold" Foreground="{StaticResource BrushPrimary}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="{Binding MigrationTitle}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding MigrationDescription}" Style="{StaticResource SmallMutedText}" Margin="0,4,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding RecentActivityTitle}" Style="{StaticResource SectionTitleText}" />
                            <Border Grid.Column="1" Style="{StaticResource BadgeBorder}">
                                <TextBlock Text="LIVE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource BrushSuccess}" />
                            </Border>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding Activity}" Margin="0,16,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BrushSurfaceAlt}" BorderBrush="{StaticResource BrushBorderSoft}" BorderThickness="1" CornerRadius="14" Padding="13" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="54" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Time}" Style="{StaticResource SmallMutedText}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Message}" TextWrapping="Wrap" FontWeight="SemiBold" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
