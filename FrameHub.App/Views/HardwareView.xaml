<UserControl x:Class="FrameHub.App.Views.HardwareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="0.9*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,16,0">
                <StackPanel>
                    <Border Style="{StaticResource HeroCardBorder}" Margin="0,0,0,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding TelemetryTitle}" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding TelemetryDescription}" Style="{StaticResource PageSubtitleText}" TextWrapping="Wrap" Margin="0,8,0,0" />
                            </StackPanel>
                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding IsMonitorEnabled}" VerticalAlignment="Center" Margin="18,0,0,0">
                                <TextBlock Text="{Binding MonitorStatus}" FontWeight="Bold" />
                            </CheckBox>
                        </Grid>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource MetricCardBorder}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="{Binding CpuLabel}" Style="{StaticResource CardTitleText}" />
                                <TextBlock Text="{Binding CpuTempText}" Style="{StaticResource CardValueText}" Margin="0,8,0,0" />
                                <TextBlock Text="{Binding BackendStatusText}" Style="{StaticResource SmallMutedText}" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource MetricCardBorder}" Margin="10,0,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding GpuLabel}" Style="{StaticResource CardTitleText}" />
                                <TextBlock Text="{Binding GpuTempText}" Style="{StaticResource CardValueText}" Margin="0,8,0,0" />
                                <TextBlock Text="{Binding BackendStatusText}" Style="{StaticResource SmallMutedText}" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource SoftCardBorder}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{Binding GpuLoadLabel}" Style="{StaticResource CardTitleText}" />
                                <TextBlock Text="{Binding GpuLoadText}" Style="{StaticResource CardValueText}" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource SoftCardBorder}" Margin="8,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{Binding RamLabel}" Style="{StaticResource CardTitleText}" />
                                <TextBlock Text="{Binding RamUsageText}" Style="{StaticResource CardValueText}" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource SoftCardBorder}" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding VramLabel}" Style="{StaticResource CardTitleText}" />
                                <TextBlock Text="{Binding VramUsageText}" Style="{StaticResource CardValueText}" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="{Binding BackgroundBehaviorTitle}" Style="{StaticResource SectionTitleText}" />
                    <Border Style="{StaticResource SoftCardBorder}" Margin="0,18,0,12">
                        <StackPanel>
                            <TextBlock Text="{Binding ProfileWatcherTitle}" FontSize="17" FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Ellipse Width="10" Height="10" Fill="{StaticResource BrushSuccess}" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding ProfileWatcherStatus}" Foreground="{StaticResource BrushTextSecondary}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SoftCardBorder}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{Binding StorageSensorsTitle}" FontSize="17" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding StorageSensorsDescription}" Style="{StaticResource SmallMutedText}" Margin="0,8,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SoftCardBorder}">
                        <StackPanel>
                            <TextBlock Text="{Binding RefreshModesTitle}" FontSize="17" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding RefreshModesDescription}" Style="{StaticResource SmallMutedText}" TextWrapping="Wrap" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
