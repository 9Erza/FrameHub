<Window x:Class="FrameHub.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="FrameHub"
        Icon="/FrameHub.App;component/Assets/FrameHub.ico"
        Height="850"
        Width="1480"
        MinHeight="760"
        MinWidth="1260"
        Background="{StaticResource BrushBackground}"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        RenderOptions.ClearTypeHint="Enabled">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38" ResizeBorderThickness="6" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border Background="{StaticResource BrushAppBackground}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Custom dark title bar for the borderless FrameHub window. -->
            <Grid Grid.Row="0" Background="{StaticResource BrushWindowChrome}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <Border Width="24" Height="24" CornerRadius="7" Background="{StaticResource BrushPrimarySoft}" Margin="0,0,10,0" BorderBrush="{StaticResource BrushBorderSoft}" BorderThickness="1" ClipToBounds="True">
                        <Image Source="/FrameHub.App;component/Assets/FrameHubLogo.png" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="Fant" />
                    </Border>
                    <TextBlock Text="FrameHub" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource BrushTextSecondary}" VerticalAlignment="Center" />
                    <Border Background="{StaticResource BrushPrimarySoft}" CornerRadius="6" Padding="8,3" Margin="12,0,0,0">
                        <TextBlock Text="{Binding AppVersion, StringFormat=v{0}}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource BrushPrimary}" />
                    </Border>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding AppTagline}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Style="{StaticResource SmallMutedText}" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button shell:WindowChrome.IsHitTestVisibleInChrome="True" Style="{StaticResource ChromeButton}" Content="—" Click="MinimizeButton_Click" ToolTip="{Binding MinimizeTooltip}" />
                    <Button shell:WindowChrome.IsHitTestVisibleInChrome="True" Style="{StaticResource ChromeButton}" Content="□" Click="MaximizeRestoreButton_Click" ToolTip="{Binding MaximizeRestoreTooltip}" />
                    <Button shell:WindowChrome.IsHitTestVisibleInChrome="True" Style="{StaticResource ChromeCloseButton}" Content="×" Click="CloseButton_Click" ToolTip="{Binding CloseTooltip}" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="312" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource BrushSidebar}"
                        BorderBrush="{StaticResource BrushBorderSoft}"
                        BorderThickness="0,0,1,0"
                        Padding="22,20,22,18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,20">
                            <Border Width="64" Height="64" CornerRadius="8" Background="{StaticResource BrushPrimarySoft}" HorizontalAlignment="Left" Margin="0,0,0,14" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" ClipToBounds="True">
                                <Grid>
                                    <Border Background="{StaticResource BrushHeroGradient}" Opacity="0.18" />
                                    <Image Source="/FrameHub.App;component/Assets/FrameHubLogo.png" Width="54" Height="54" HorizontalAlignment="Center" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="Fant" />
                                </Grid>
                            </Border>
                            <TextBlock Text="{Binding AppName}" FontSize="26" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding AppTagline}" Style="{StaticResource SmallMutedText}" Margin="0,5,0,0" TextWrapping="Wrap" />
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding NavigationItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <RadioButton Style="{StaticResource NavRadioButton}"
                                                     IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                     Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                     CommandParameter="{Binding Key}"
                                                     Opacity="{Binding ItemOpacity}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="34" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Icon}"
                                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol"
                                                           FontSize="15"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{Binding Title}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                <Border Grid.Column="2" Style="{StaticResource BadgeBorder}" Visibility="{Binding BadgeVisibility}" Margin="10,0,0,0">
                                                    <TextBlock Text="{Binding Badge}" FontSize="9" FontWeight="Bold" Foreground="{StaticResource BrushTextSecondary}" />
                                                </Border>
                                            </Grid>
                                        </RadioButton>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <StackPanel Grid.Row="2" Margin="0,18,0,0">
                            <Border Style="{StaticResource SoftCardBorder}" Padding="13" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="{Binding LanguageLabel}" Style="{StaticResource TinyCapsText}" Margin="0,0,0,10" />
                                    <ItemsControl ItemsSource="{Binding LanguageOptions}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource LanguageButton}"
                                                        Command="{Binding DataContext.SetLanguageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding Code}"
                                                        ToolTip="{Binding DisplayName}">
                                                    <Grid Width="42" Height="30">
                                                        <Border CornerRadius="8" Background="{StaticResource BrushSurfaceHover}" Padding="3">
                                                            <Border CornerRadius="5" ClipToBounds="True">
                                                                <Image Source="{Binding FlagSource}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" />
                                                            </Border>
                                                        </Border>
                                                        <Border BorderBrush="{StaticResource BrushPrimary}" BorderThickness="2" CornerRadius="8" Visibility="{Binding SelectedVisibility}" />
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SoftCardBorder}" Padding="15">
                                <StackPanel>
                                    <TextBlock Text="FRAMEHUB" Style="{StaticResource TinyCapsText}" Foreground="{StaticResource BrushPrimary}" />
                                    <TextBlock Text="{Binding AppVersion, StringFormat=v{0}}" Margin="0,4,0,0" FontSize="16" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <Ellipse Width="9" Height="9" Fill="{StaticResource BrushSuccess}" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding WatcherStatus}" Style="{StaticResource SmallMutedText}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="32,28,32,30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="FRAMEHUB" Style="{StaticResource PageEyebrowText}" />
                            <TextBlock Text="{Binding CurrentTitle}" Style="{StaticResource PageTitleText}" Margin="0,6,0,0" />
                            <TextBlock Text="{Binding CurrentSubtitle}" Style="{StaticResource PageSubtitleText}" Margin="0,7,0,0" />
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource SoftCardBorder}" Padding="14,9" VerticalAlignment="Top">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="10" Height="10" Fill="{StaticResource BrushSuccess}" Margin="0,0,9,0" />
                                <TextBlock Text="{Binding CoreFoundationStatus}" Foreground="{StaticResource BrushTextSecondary}" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
